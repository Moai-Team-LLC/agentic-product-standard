#!/usr/bin/env sh
# Dependency-free Conventional Commits check. The Standard is a docs-only repo
# with no Node toolchain, so unlike the code repos in the family it cannot run
# commitlint locally. This hook gives the same fast, zero-dependency local
# feedback the family's resilient hook falls back to; CI's commitlint job is the
# full backstop. Enable it with:  git config core.hooksPath .githooks
# (setup.sh does this for you).
msg_file="$1"
header=$(head -n 1 "$msg_file")

# Merge/revert/fixup autogenerated headers carry no conventional type — skip.
case "$header" in
  "Merge "*|"Revert \""*|"fixup! "*|"squash! "*) exit 0 ;;
esac

fail=0
if [ "${#header}" -gt 72 ]; then
  echo "commit-msg: header is ${#header} chars (max 72) — shorten it." >&2
  fail=1
fi

types='feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert'
if ! printf '%s' "$header" | grep -Eq "^(${types})(\([a-z0-9 ._/-]+\))?!?: .+"; then
  echo "commit-msg: header is not a Conventional Commit." >&2
  echo "  expected: <type>[optional scope][!]: <description>" >&2
  echo "  types: ${types}" >&2
  fail=1
fi

if [ "$fail" -ne 0 ]; then
  echo "  (CI runs the full commitlint ruleset; this local check is dependency-free.)" >&2
  exit 1
fi
